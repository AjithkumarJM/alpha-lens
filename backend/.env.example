# Server Configuration
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/stock_analysis

# API Keys
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
TWELVEDATA_API_KEY=your_twelvedata_key_here
FINNHUB_API_KEY=your_finnhub_key_here

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Cache Configuration
CACHE_TTL_INTRADAY=300
CACHE_TTL_DAILY=86400
CACHE_TTL_ANALYSIS=86400
CACHE_TTL_FUNDAMENTALS=604800

# Scheduler (IST timezone)
MARKET_CLOSE_HOUR=15
MARKET_CLOSE_MINUTE=45
ANALYSIS_RUN_HOUR=16
ANALYSIS_RUN_MINUTE=0

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Alerting (Optional)
SLACK_WEBHOOK_URL=
SENDGRID_API_KEY=
ALERT_EMAIL=your_email@example.com

# Monitoring
SENTRY_DSN=
